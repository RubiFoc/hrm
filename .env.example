# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://hrm:hrm@postgres:5432/hrm
REDIS_URL=redis://redis:6379/0
HRM_JWT_SECRET=hrm-dev-secret-change-me
HRM_JWT_ALGORITHM=HS256
HRM_ACCESS_TOKEN_TTL_SECONDS=900
HRM_REFRESH_TOKEN_TTL_SECONDS=604800
HRM_AUTH_REDIS_PREFIX=auth:deny
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
# Source-of-truth bucket variable for backend and MinIO bootstrap.
OBJECT_STORAGE_BUCKET=hrm-documents
OBJECT_STORAGE_SSE_ENABLED=true
CV_ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
CV_MAX_SIZE_BYTES=10485760
CV_PARSING_MAX_ATTEMPTS=3
EMPLOYEE_KEY_TTL_SECONDS=604800
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_DEFAULT_QUEUE=cv_parsing
CELERY_TASK_TIME_LIMIT_SECONDS=120
CELERY_TASK_ALWAYS_EAGER=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
GOOGLE_CALENDAR_ENABLED=false

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
VITE_SENTRY_DSN=

# Infrastructure
POSTGRES_DB=hrm
POSTGRES_USER=hrm
POSTGRES_PASSWORD=hrm
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
