{
  "name": "hrm-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest",
    "api:types:generate": "npx --yes openapi-typescript@7.5.2 ../../docs/api/openapi.frozen.json -o src/api/generated/openapi-types.ts",
    "api:types:check": "npm run api:types:generate && test -s src/api/generated/openapi-types.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^3.9.1",
    "@mui/material": "^6.1.0",
    "@sentry/react": "^9.15.0",
    "@tanstack/react-query": "^5.56.2",
    "i18next": "^24.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "react-i18next": "15.7.4",
    "react-router-dom": "^7.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0",
    "vitest": "^2.1.8"
  }
